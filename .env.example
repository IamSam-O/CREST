DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=*

# Required if served through a reverse proxy (e.g. Nginx Proxy Manager) on
# a public domain - the exact https:// origin(s) the app is reachable at.
# Comma-separated if more than one.
# DJANGO_CSRF_TRUSTED_ORIGINS=https://your-domain.example.com

# SMTP credentials are configured from the UI at /manage/ (Email Settings section), not here.

# The secret key is auto-generated on first run and saved to data/.secret_key.
# No manual configuration needed.
